generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id           String        @id @default(uuid())
  name         String
  industry     String?
  country      String?
  timezone     String?
  subscription String        @default("starter")
  status       String        @default("active")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  users        User[]
  departments  Department[]
  projects     Project[]
  clients      Client[]
  settings     Setting[]
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  password       String
  name           String?
  role           String         @default("employee")
  status         String         @default("active")
  avatar         String?
  lastLogin      DateTime?
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  conversations  Conversation[]
  notifications  Notification[]
  auditLogs      AuditLog[]
  settings       Setting[]
}

model Department {
  id             String       @id @default(uuid())
  name           String
  description    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  status         String       @default("active")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  agents         Agent[]
}

model Agent {
  id            String      @id @default(uuid())
  name          String
  role          String
  capabilities  String[]
  assignedModel String      @default("gemini-2.0-flash")
  status        String      @default("idle")
  version       String      @default("1.0.0")
  health        String      @default("healthy")
  departmentId  String
  department    Department  @relation(fields: [departmentId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  tasks         Task[]
  auditLogs     AuditLog[]
}

model Project {
  id             String         @id @default(uuid())
  title          String
  description    String?
  status         String         @default("planning")
  priority       String         @default("medium")
  budget         Float?
  startDate      DateTime?
  endDate        DateTime?
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  clientId       String?
  client         Client?        @relation(fields: [clientId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  tasks          Task[]
  workflows      Workflow[]
  conversations  Conversation[]
  memory         Memory[]
  documents      Document[]
}

model Task {
  id            String    @id @default(uuid())
  title         String
  description   String?
  priority      String    @default("medium")
  status        String    @default("pending")
  dependencies  String[]
  deadline      DateTime?
  estimatedCost Float?
  executionTime Int?
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id])
  assignedAgentId String?
  assignedAgent   Agent?    @relation(fields: [assignedAgentId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Workflow {
  id            String    @id @default(uuid())
  name          String
  executionType String    @default("sequential")
  currentStage  String?
  status        String    @default("not_started")
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id])
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
}

model Client {
  id             String       @id @default(uuid())
  name           String
  industry       String?
  contactPerson  String?
  email          String?
  phone          String?
  country        String?
  preferences    Json?
  status         String       @default("active")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  projects       Project[]
}

model Conversation {
  id        String    @id @default(uuid())
  status    String    @default("open")
  summary   String?
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id])
  createdAt DateTime  @default(now())
  closedAt  DateTime?
  messages  Message[]
}

model Message {
  id             String       @id @default(uuid())
  sender         String
  receiver       String?
  content        String
  modelUsed      String?
  tokenCount     Int?
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  createdAt      DateTime     @default(now())
}

model Memory {
  id                  String   @id @default(uuid())
  category            String
  summary             String
  embeddingReference  String?
  confidence          Float?
  accessLevel         String   @default("internal")
  projectId           String?
  project             Project? @relation(fields: [projectId], references: [id])
  department          String?
  client              String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Document {
  id         String   @id @default(uuid())
  title      String
  category   String
  ownerId    String
  version    String   @default("1.0.0")
  storageUrl String
  status     String   @default("active")
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Notification {
  id        String    @id @default(uuid())
  message   String
  priority  String    @default("medium")
  status    String    @default("unread")
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
  readAt    DateTime?
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  resource  String
  status    String
  ipAddress String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  agentId   String?
  agent     Agent?   @relation(fields: [agentId], references: [id])
  createdAt DateTime @default(now())
}

model Setting {
  id             String        @id @default(uuid())
  key            String
  value          Json
  userId         String?
  user           User?         @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  updatedAt      DateTime      @updatedAt

  @@unique([key, userId, organizationId])
}

