{
  "name": "@oracle69/execution-engine",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "test": "jest"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.2"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@oracle69/shared": "workspace:*",
    "@oracle69/agent-engine": "workspace:*"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@oracle69/shared(|/.*)$": "<rootDir>/../../shared/src/$1",
      "^@oracle69/agent-engine(|/.*)$": "<rootDir>/../../agent-engine/src/$1"
    }
  }
}
